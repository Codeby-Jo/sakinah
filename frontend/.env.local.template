# ── Sakinah · Shukr Mode — dev config ─────────────────────────────────────────
# Copy this file to ".env.local" and paste the web config from YOUR OWN
# throwaway Firebase project:
#   Firebase Console → Project settings → General → Your apps → Web app
# These are client-side config values (not secrets) for a throwaway dev project.
# Do NOT use any production project. Do NOT commit .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Your Sakinah backend ──────────────────────────────────────────────────────
# Point this at the Python/FastAPI backend you build and run locally.
VITE_BACKEND_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# Set to 'true' to use the Firebase Auth emulator (bypasses rate limits in dev).
VITE_USE_AUTH_EMULATOR=false

# Push notifications (optional, not needed for matchmaking) — leave blank.
VITE_FIREBASE_VAPID_KEY=

# Feature flag for an unrelated module — leave off.
VITE_ENABLE_EIM_MIRROR=false
